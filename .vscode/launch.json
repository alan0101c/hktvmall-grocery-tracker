{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Frontend (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/grocery-tracker/src",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    },
    {
      "name": "Debug Vite Dev Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/grocery-tracker/node_modules/.bin/vite",
      "args": ["--host", "0.0.0.0", "--port", "3000"],
      "cwd": "${workspaceFolder}/grocery-tracker",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}